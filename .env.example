# GitHub fixture repo used by setup_github.sh and eval runners.
EVAL_REPO=OWNER/acme-agent-evals

# Optional override. Defaults to the current repo checkout.
FIXTURE_WORKTREE=

# Arize AX credentials.
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# Model provider credentials.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# GitHub token. If set, runners pass it through as GH_TOKEN/GITHUB_TOKEN.
GITHUB_PERSONAL_ACCESS_TOKEN=

# Eval defaults.
MODEL_MATRIX=configs/model_matrix.json
RUNNER=pi
RUNS=3
PI_THINKING=medium
